# === Discord ===
# Bot-Token aus dem Discord Developer Portal (Bot -> Reset Token)
DISCORD_TOKEN=dein_bot_token_hier
# Application/Client-ID (General Information -> Application ID)
CLIENT_ID=deine_client_id_hier
# Optional: Test-Guild-ID für sofortiges Command-Deployment (Entwicklung).
# Leer lassen für globales Deployment (kann bis zu 1h dauern).
TEST_GUILD_ID=

# === Datenbank (PostgreSQL) ===
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATENBANK
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/verwaltungsbot

# === Web-Portal (lumiya.justplaysx.de) ===
# Client-Secret aus dem Developer Portal (OAuth2 -> Client Secret)
AUTH_DISCORD_SECRET=dein_client_secret_hier
# Auth.js-Secret – erzeugen mit:  openssl rand -base64 32
AUTH_SECRET=bitte_ersetzen
# Öffentliche URL des Portals
AUTH_URL=https://lumiya.justplaysx.de

# === Docker-Compose (Datenbank-Passwort für den Postgres-Container) ===
POSTGRES_PASSWORD=ein_sicheres_passwort

# === Sonstiges ===
# debug | info | warn | error
LOG_LEVEL=info
NODE_ENV=development

{
  "name": "discord-verwaltungsbot",
  "version": "0.1.0",
  "description": "Umfangreicher Discord-Verwaltungsbot (Moderation, AutoMod, Leveling, Welcome/Rollen, Tickets, Honeypot/Anti-Raid)",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "deploy": "tsx src/deploy-commands.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.27.0",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}

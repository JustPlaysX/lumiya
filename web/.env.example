# === Discord OAuth2 (Developer Portal -> OAuth2) ===
AUTH_DISCORD_ID=deine_client_id
AUTH_DISCORD_SECRET=dein_client_secret

# Bot-Token (zum Auflisten der Server & Nutzernamen)
DISCORD_BOT_TOKEN=dein_bot_token

# Auth.js-Secret – erzeugen mit:  openssl rand -base64 32
AUTH_SECRET=bitte_ersetzen

# Öffentliche URL des Portals (für OAuth-Redirect hinter nginx)
AUTH_URL=https://lumiya.justplaysx.de

# Gleiche PostgreSQL-DB wie der Bot
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/verwaltungsbot

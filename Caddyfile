# Caddy stellt die Domain automatisch mit HTTPS bereit und leitet
# die Anfragen intern an das Web-Portal (Container "web", Port 3000) weiter.
# Caddy holt & erneuert das Let's-Encrypt-Zertifikat vollautomatisch.

# Optional: eigene E-Mail für Let's-Encrypt-Ablaufhinweise eintragen
# (Zeile einkommentieren und Adresse anpassen). Ohne funktioniert es auch.
# {
# 	email deine@email.de
# }

lumiya.justplaysx.de {
	reverse_proxy web:3000
}
